# ============================================================
# .env.example — Copy to .env and fill in your values
# ============================================================

# ── Google Drive ──────────────────────────────────────────
# Path to your service-account JSON key file
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# ID of the root Drive folder to scan (from the URL)
# e.g. https://drive.google.com/drive/folders/<THIS_ID>
DRIVE_ROOT_FOLDER_ID=

# ── Tesseract (Windows only) ──────────────────────────────
# Comment out or leave empty on Linux/macOS if tesseract is on PATH
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# ── Processing ────────────────────────────────────────────
PDF_DPI=300
DOWNLOAD_DIR=downloads
OUTPUT_DIR=output

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS origins (comma-separated) ───────────────────────
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000
